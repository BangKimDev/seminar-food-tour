{
  "entities": {
    "poi": {
      "title": "Point of Interest",
      "description": "A specific location on the map with a category.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the POI" },
        "description": { "type": "string", "description": "Description of the POI" },
        "type": { 
          "type": "string", 
          "enum": ["main", "wc", "ticket", "parking", "boat_dock"],
          "description": "Category of the POI" 
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "location"]
    },
    "tour": {
      "title": "Tour",
      "description": "A sequence of POIs forming a sightseeing route.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the tour" },
        "description": { "type": "string", "description": "Description of the tour" },
        "poiIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Ordered list of POI IDs"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "poiIds"]
    }
  },
  "firestore": {
    "/pois": { "schema": "poi", "description": "Collection of points of interest" },
    "/tours": { "schema": "tour", "description": "Collection of tours" }
  }
}
