rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: pois
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - type: string (required, enum: main, wc, ticket, parking, boat_dock)
    //   - location: map (required)
    //     - lat: number
    //     - lng: number
    //   - createdAt: timestamp (required)
    //
    // Collection: tours
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - poiIds: list of strings (required, max 50 items)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ryushiki12@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidPoi(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.description == null || (data.description is string && data.description.size() <= 500)) &&
             data.type in ['main', 'wc', 'ticket', 'parking', 'boat_dock'] &&
             data.location is map &&
             data.location.lat is number &&
             data.location.lng is number &&
             data.createdAt is timestamp;
    }

    function isValidTour(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.description == null || (data.description is string && data.description.size() <= 500)) &&
             data.poiIds is list && data.poiIds.size() <= 50 &&
             data.createdAt is timestamp;
    }

    // POIs Collection
    match /pois/{poiId} {
      allow read, write: if true;
    }

    // Tours Collection
    match /tours/{tourId} {
      allow read, write: if true;
    }
  }
}
